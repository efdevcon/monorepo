# DevaBot RAG backend (devcon-ai service, see ../devcon-ai)
NEXT_PUBLIC_DEVABOT_API_URL=http://localhost:3030

PRETALX_API_KEY=your_pretalx_api_key

# Devcon API (data provider) — NEXT_PUBLIC_ so it's available in the browser.
# Use the hosted API, or http://localhost:4000 for a local devcon-api.
NEXT_PUBLIC_DEVCON_API_URL=https://api.devcon.org
# Default dataset shown when no ?dataset param is set. One of:
# test-devcon-8 | devcon8 | devcon-7. Unset falls back to devcon-7.
# All three remain selectable at runtime via the debug panel regardless.
NEXT_PUBLIC_DEVCON_API_EVENT_ID=devcon-7

# Debug panel (dataset switcher + time mocking). Auto-on in local dev. In
# production set to "true" to always show it, or just append ?debug=1 to any URL.
# Do NOT enable it by setting NODE_ENV=development (that breaks the prod build).
NEXT_PUBLIC_ENABLE_DEBUG=false

# Supabase (email-OTP login)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Pretix (ticket fetching) — server-only, used by /api/tickets
PRETIX_API_URL=https://ticketh.xyz
PRETIX_ORGANIZER=your_organizer_slug
PRETIX_EVENT=your_event_slug
PRETIX_EVENT_NAME=Devcon
PRETIX_API_KEY=your_pretix_api_key
