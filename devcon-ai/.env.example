# Server
PORT=3001

# Supabase
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...
# Used to validate user session tokens for the requireAuth gate. Either key
# works; anon is preferred (least privilege). All /api routes require a valid
# Supabase session token UNLESS NODE_ENV=development (the dev script sets this).
SUPABASE_ANON_KEY=eyJ...

# Gemini (for image generation)
GEMINI_API_KEY=AIza...

# Chat Provider (openai | huggingface)
CHAT_PROVIDER=openai

# OpenAI (always used for embeddings; also used for chat if CHAT_PROVIDER=openai
# and OPENAI_BASE_URL is unset)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Optional: point the chat client at an OpenAI-compatible endpoint
# (e.g. EF Inference: https://inference.ethereum.foundation/v1).
# Embeddings always use OPENAI_API_KEY against real OpenAI.
# OPENAI_BASE_URL=https://inference.ethereum.foundation/v1
# OPENAI_CHAT_API_KEY=sk-your-ef-key   # falls back to EF_INFERENCE_API_KEY, then OPENAI_API_KEY
# OPENAI_MODEL=openai/gpt-oss-120b

# Hugging Face (for chat if CHAT_PROVIDER=huggingface)
# Get your token at: https://huggingface.co/settings/tokens
HF_API_TOKEN=hf_...
HF_MODEL=meta-llama/Llama-3.1-8B-Instruct

# Recommended HF models:
# - meta-llama/Llama-3.1-8B-Instruct (good default, balanced)
# - mistralai/Mistral-7B-Instruct-v0.3 (fast, good quality)
# - Qwen/Qwen2.5-7B-Instruct (strong instruction following)
# - microsoft/Phi-3-mini-4k-instruct (small but capable)
