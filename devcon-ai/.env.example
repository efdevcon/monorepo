# Server
PORT=3001

# Supabase
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# Gemini (for image generation)
GEMINI_API_KEY=AIza...

# Chat Provider (openai | huggingface)
CHAT_PROVIDER=openai

# OpenAI (for embeddings, and chat if CHAT_PROVIDER=openai)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Hugging Face (for chat if CHAT_PROVIDER=huggingface)
# Get your token at: https://huggingface.co/settings/tokens
HF_API_TOKEN=hf_...
HF_MODEL=meta-llama/Llama-3.1-8B-Instruct

# Recommended HF models:
# - meta-llama/Llama-3.1-8B-Instruct (good default, balanced)
# - mistralai/Mistral-7B-Instruct-v0.3 (fast, good quality)
# - Qwen/Qwen2.5-7B-Instruct (strong instruction following)
# - microsoft/Phi-3-mini-4k-instruct (small but capable)
