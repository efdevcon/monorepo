{
  "name": "devcon-ai",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "sync:devcon": "tsx scripts/sync-documents.ts --source-type github --source-repo devcon --path ../devcon/cms",
    "sync:devconnect": "tsx scripts/sync-documents.ts --source-type github --source-repo devconnect --path ../devconnect/cms",
    "sync:devcon-api": "tsx scripts/sync-devcon-api.ts",
    "test:providers": "tsx scripts/test-providers.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.21.0",
    "openai": "^4.77.0",
    "typescript": "^5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "tsx": "^4.19.0"
  }
}
